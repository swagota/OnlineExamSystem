<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f4ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.ViewQuestionsController">


    <AnchorPane layoutX="0" layoutY="0" prefHeight="70.0" prefWidth="900" style="-fx-background-color: #1a2a4a;">
        <Label layoutX="30" layoutY="18" style="-fx-text-fill: white; -fx-font-size: 24px;                       -fx-font-weight: bold; -fx-font-family: 'Berlin Sans FB';" text="EXAMORA" />
        <Label layoutX="385.0" layoutY="22.0" style="-fx-text-fill: #6a9ae7; -fx-font-size: 18px; -fx-font-weight: bold;" text="View Questions" />
        <Button fx:id="backBtn" layoutX="800" layoutY="18.0" onAction="#handleBack" prefHeight="35" prefWidth="80" style="-fx-background-color: #6a9ae7; -fx-text-fill: white;                        -fx-font-size: 13px; -fx-background-radius: 8px; -fx-font-weight: bold;" text="◀ Back" />
    </AnchorPane>
    <Circle layoutX="80" layoutY="520" radius="100" style="-fx-fill: rgba(106,154,231,0.04);" />


    <ScrollPane fx:id="scrollPane" fitToWidth="true" layoutX="50.0" layoutY="131.0" prefHeight="420" prefWidth="800" style="-fx-background-color: transparent;                        -fx-background: transparent;                        -fx-border-color: transparent;">
        <content>
            <VBox fx:id="questionsContainer" spacing="12" style="-fx-padding: 5px 5px 15px 5px; -fx-background-color: transparent;" />
        </content>
    </ScrollPane>

</AnchorPane>
