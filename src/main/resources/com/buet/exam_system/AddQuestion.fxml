<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.AddQuestionController">
   <children>
      <HBox prefHeight="135.0" prefWidth="600.0">
         <children>
            <AnchorPane prefHeight="127.0" prefWidth="612.0">
               <children>
                  <TextArea fx:id="questionField" prefHeight="168.0" prefWidth="618.0" promptText="Enter Question here" />
               </children>
            </AnchorPane>
         </children>
      </HBox>
      <VBox layoutX="14.0" layoutY="135.0" prefHeight="70.0" prefWidth="579.0">
         <children>
            <Region prefHeight="27.0" prefWidth="579.0" />
         </children>
      </VBox>
      <VBox layoutY="205.0" prefHeight="70.0" prefWidth="594.0">
         <children>
            <Region prefHeight="0.0" prefWidth="594.0" />
            <Region prefHeight="0.0" prefWidth="594.0" />
            <TextField fx:id="option1Field" prefHeight="50.0" prefWidth="566.0" promptText="Option 1" />
         </children>
      </VBox>
      <TextField fx:id="option4Field" layoutY="385.0" prefHeight="50.0" prefWidth="594.0" promptText="Option 4" />
      <TextField fx:id="option3Field" layoutX="-2.0" layoutY="328.0" prefHeight="50.0" prefWidth="594.0" promptText="Option 3" />
      <TextField fx:id="option2Field" layoutY="269.0" prefHeight="50.0" prefWidth="594.0" promptText="Option 2" />
      <ComboBox fx:id="correctBox" layoutX="1.0" layoutY="465.0" prefHeight="42.0" prefWidth="182.0" promptText="Select Correct Option" />
      <Button fx:id="saveBtn" layoutX="491.0" layoutY="477.0" mnemonicParsing="false" onAction="#saveQuestion" prefHeight="35.0" prefWidth="86.0" text="SAVE" />
      <ButtonBar layoutX="14.0" layoutY="532.0" prefHeight="40.0" prefWidth="200.0" />
    <Button fx:id="backBtn" layoutX="-2.0" layoutY="573.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="26.0" prefWidth="86.0" text="BACK" />
   </children>
</AnchorPane>
