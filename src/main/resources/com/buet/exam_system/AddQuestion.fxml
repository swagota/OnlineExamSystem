<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="620.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.buet.exam_system.AddQuestionController">
   <children>

      <!-- Exam info label at top -->
      <Label fx:id="examInfoLabel" layoutX="14.0" layoutY="8.0"
             style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #34495e;"
             text="Add Question" />

      <!-- Question text area -->
      <TextArea fx:id="questionField" layoutY="30.0"
                prefHeight="130.0" prefWidth="800.0"
                promptText="Q1. Enter question here..." wrapText="true"/>

      <!-- Options -->
      <TextField fx:id="option1Field" layoutY="168.0" prefHeight="46.0" prefWidth="800.0" promptText="Option 1" />
      <TextField fx:id="option2Field" layoutY="218.0" prefHeight="46.0" prefWidth="800.0" promptText="Option 2" />
      <TextField fx:id="option3Field" layoutY="268.0" prefHeight="46.0" prefWidth="800.0" promptText="Option 3" />
      <TextField fx:id="option4Field" layoutY="318.0" prefHeight="46.0" prefWidth="800.0" promptText="Option 4" />

      <!-- Correct option selector -->
      <ComboBox fx:id="correctBox" layoutX="1.0" layoutY="375.0"
                prefHeight="42.0" prefWidth="220.0"
                promptText="Select Correct Option" />

      <!-- Save button -->
      <Button fx:id="saveBtn" layoutX="680.0" layoutY="385.0"
              mnemonicParsing="false" onAction="#handleSave"
              prefHeight="35.0" prefWidth="100.0" text="SAVE"
              style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" />

      <!-- Back button -->
      <Button fx:id="BackBtn" layoutX="1.0" layoutY="580.0"
              mnemonicParsing="false" onAction="#handleBack"
              prefHeight="30.0" prefWidth="90.0" text="BACK" />

   </children>
</AnchorPane>

