<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f4ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.CreateExamController">


   <AnchorPane layoutX="0" layoutY="0" prefHeight="70" prefWidth="900" style="-fx-background-color: #1a2a4a;">
      <Label layoutX="30" layoutY="18" style="-fx-text-fill: white; -fx-font-size: 24px;                       -fx-font-weight: bold; -fx-font-family: 'Berlin Sans FB';" text="EXAMORA" />
      <Label layoutX="376.0" layoutY="21.0" style="-fx-text-fill: #6a9ae7; -fx-font-size: 18px; -fx-font-weight: bold;" text="Create New Exam" />

      <Button fx:id="backBtn" layoutX="800" layoutY="17.0" onAction="#handleBack" prefHeight="35" prefWidth="80" style="-fx-background-color: #6a9ae7; -fx-text-fill: white;                        -fx-font-size: 13px; -fx-background-radius: 8px;                        -fx-font-weight: bold;" text="◀ Back" />
   </AnchorPane>
   <Circle layoutX="100" layoutY="500" radius="120" style="-fx-fill: rgba(106,154,231,0.04);" />


   <AnchorPane layoutX="199.0" layoutY="127.0" prefHeight="430" prefWidth="500" style="-fx-background-color: white;                        -fx-background-radius: 20px;                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 25, 0, 0, 8);                        -fx-border-color: #dce8ff;                        -fx-border-radius: 20px;                        -fx-border-width: 1px;">


      <Rectangle height="80" layoutX="0" layoutY="0" style="-fx-fill: linear-gradient(to right, #1a2a4a, #2a4a7a);                           -fx-arc-width: 20; -fx-arc-height: 20;" width="500" />

      <Rectangle height="20" layoutX="0" layoutY="60" style="-fx-fill: linear-gradient(to right, #1a2a4a, #2a4a7a);" width="500" />

      <Label alignment="CENTER" layoutX="0" layoutY="22" prefWidth="500" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="📝  New Exam" />


      <Label fx:id="teacherNameLabel" alignment="CENTER" layoutX="0" layoutY="54" prefWidth="500" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-style: italic;" text="By — Teacher Sir" />


      <Label layoutX="40" layoutY="105" style="-fx-text-fill: #1a2a4a; -fx-font-size: 13px; -fx-font-weight: bold;" text="Exam Name" />


      <TextField fx:id="examNameField" layoutX="40" layoutY="128" prefHeight="45" prefWidth="420" promptText="e.g. Mid-Term Mathematics 2025" style="-fx-background-color: #f0f4ff;                           -fx-border-color: #c0d0f0;                           -fx-border-radius: 10px;                           -fx-background-radius: 10px;                           -fx-border-width: 1.5px;                           -fx-font-size: 13px;                           -fx-padding: 0 15px;" />


      <Label layoutX="40" layoutY="195" style="-fx-text-fill: #1a2a4a; -fx-font-size: 13px; -fx-font-weight: bold;" text="Time Limit (minutes)" />


      <TextField fx:id="totalTimeField" layoutX="40" layoutY="218" prefHeight="45" prefWidth="420" promptText="e.g. 60" style="-fx-background-color: #f0f4ff;                           -fx-border-color: #c0d0f0;                           -fx-border-radius: 10px;                           -fx-background-radius: 10px;                           -fx-border-width: 1.5px;                           -fx-font-size: 13px;                           -fx-padding: 0 15px;" />


      <AnchorPane layoutX="40" layoutY="285" prefHeight="55" prefWidth="420" style="-fx-background-color: rgba(106,154,231,0.08);                            -fx-background-radius: 10px;                            -fx-border-color: rgba(106,154,231,0.3);                            -fx-border-radius: 10px;                            -fx-border-width: 1px;">
         <Label layoutX="15" layoutY="8" style="-fx-font-size: 16px;" text="ℹ️" />
         <Label layoutX="42" layoutY="10" style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;" text="After creating the exam, you'll be taken to add questions." />
         <Label layoutX="42" layoutY="28" style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;" text="You can add as many questions as needed." />
      </AnchorPane>


      <Button fx:id="createBtn" layoutX="40" layoutY="360" onAction="#handleCreate" prefHeight="50" prefWidth="420" style="-fx-background-color: linear-gradient(to right, #1a2a4a, #2a5a9a);                        -fx-text-fill: white;                        -fx-font-size: 15px;                        -fx-font-weight: bold;                        -fx-background-radius: 12px;" text="✅   Create Exam" />

   </AnchorPane>
   <Circle layoutX="49.0" layoutY="144.0" radius="120" style="-fx-fill: rgba(106,154,231,0.04);" />

</AnchorPane>
