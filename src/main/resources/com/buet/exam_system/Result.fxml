<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f4ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.ResultController">


    <AnchorPane layoutX="0" layoutY="0" prefHeight="70" prefWidth="900" style="-fx-background-color: #1a2a4a;">
        <Label layoutX="30" layoutY="18" style="-fx-text-fill: white; -fx-font-size: 24px;                       -fx-font-weight: bold; -fx-font-family: 'Berlin Sans FB';" text="EXAMORA" />
        <Label layoutX="448.0" layoutY="21.0" style="-fx-text-fill: #6a9ae7; -fx-font-size: 18px; -fx-font-weight: bold;" text="Exam Result" />
    </AnchorPane>


    <Circle layoutX="820" layoutY="450" radius="180" style="-fx-fill: rgba(106,154,231,0.06);" />
    <Circle layoutX="80" layoutY="520" radius="120" style="-fx-fill: rgba(106,154,231,0.04);" />

    <AnchorPane layoutX="294.0" layoutY="126.0" prefHeight="400" prefWidth="500" style="-fx-background-color: white;                        -fx-background-radius: 20px;                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 25, 0, 0, 8);                        -fx-border-color: #dce8ff; -fx-border-radius: 20px; -fx-border-width: 1px;">


        <Rectangle height="70" layoutX="0" layoutY="0" style="-fx-fill: linear-gradient(to right, #1a2a4a, #2a4a7a);                           -fx-arc-width: 20; -fx-arc-height: 20;" width="500" />
        <Rectangle height="20" layoutX="0" layoutY="50" style="-fx-fill: linear-gradient(to right, #1a2a4a, #2a4a7a);" width="500" />


        <Label fx:id="emojiLabel" alignment="CENTER" layoutX="0" layoutY="12" prefWidth="500" style="-fx-font-size: 36px;" text="🎉" />


        <Label fx:id="scoreLabel" alignment="CENTER" layoutX="0" layoutY="90" prefWidth="500" style="-fx-font-size: 58px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;" text="0 / 0" />


        <Label fx:id="percentLabel" alignment="CENTER" layoutX="0" layoutY="168" prefWidth="500" style="-fx-font-size: 14px; -fx-text-fill: #999;" text="0.0% correct" />


        <Label layoutX="50" layoutY="198" prefWidth="400" style="-fx-border-color: #eef2ff; -fx-border-width: 1px 0 0 0;" text="" />


        <AnchorPane layoutX="50" layoutY="212" prefHeight="60" prefWidth="400" style="-fx-background-color: #f8faff; -fx-background-radius: 10px;">
            <Label layoutX="20" layoutY="10" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="✅ Correct" />
            <Label fx:id="correctLabel" layoutX="20" layoutY="30" style="-fx-text-fill: #27ae60; -fx-font-size: 18px; -fx-font-weight: bold;" text="0" />

            <Label layoutX="175" layoutY="10" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="❌ Wrong" />
            <Label fx:id="wrongLabel" layoutX="175" layoutY="30" style="-fx-text-fill: #e74c3c; -fx-font-size: 18px; -fx-font-weight: bold;" text="0" />

            <Label layoutX="320" layoutY="10" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="📋 Total" />
            <Label fx:id="totalLabel" layoutX="320" layoutY="30" style="-fx-text-fill: #1a2a4a; -fx-font-size: 18px; -fx-font-weight: bold;" text="0" />
        </AnchorPane>


        <Button fx:id="backBtn" layoutX="75" layoutY="310" onAction="#handleBack" prefHeight="48" prefWidth="350" style="-fx-background-color: linear-gradient(to right, #1a2a4a, #2a5a9a);                        -fx-text-fill: white; -fx-font-size: 14px;                        -fx-font-weight: bold; -fx-background-radius: 12px;" text="◀   Back to Exams" />

    </AnchorPane>

</AnchorPane>
