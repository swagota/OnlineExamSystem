<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.buet.exam_system.StudentDashboardController"
            style="-fx-background-color: #f0f4ff;">

   <!-- TOP BAR -->
   <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="70.0" prefWidth="900.0"
               style="-fx-background-color: #1a2a4a;">

      <!-- App Title -->
      <Label layoutX="30.0" layoutY="18.0" text="EXAMORA"
             style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>

      <!-- Welcome Message -->
      <Label fx:id="welcomeLabel" layoutX="300.0" layoutY="22.0" text="WELCOME, Student!"
             style="-fx-text-fill: #6a9ae7; -fx-font-size: 18px; -fx-font-weight: bold;"/>

      <!-- Logout Button -->
      <Button fx:id="logoutBtn" layoutX="800.0" layoutY="18.0"
              text="Logout" onAction="#handleLogout"
              style="-fx-background-color: #e74c3c;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-background-radius: 8px;
                       -fx-cursor: hand;"
              prefWidth="80.0" prefHeight="35.0"/>
   </AnchorPane>

   <!-- LEFT SIDEBAR -->
   <AnchorPane layoutX="0.0" layoutY="70.0" prefHeight="530.0" prefWidth="200.0"
               style="-fx-background-color: #1e3a5f;">

      <!-- Student Icon Label -->
      <Label layoutX="75.0" layoutY="30.0" text="👤"
             style="-fx-font-size: 50px;"/>

      <!-- Student Name -->
      <Label fx:id="studentName"
             layoutX="0.0"
             layoutY="95.0"
             prefWidth="200.0"
             alignment="CENTER"
             text="Student Name"
             style="-fx-text-fill: white; -fx-font-size: 14px;"/>

      <!-- Divider -->
      <Label layoutX="10.0" layoutY="130.0" prefWidth="180.0" text="─────────────────"
             style="-fx-text-fill: #6a9ae7;"/>

      <!-- Start Exam Button -->
      <Button fx:id="startBtn" layoutX="20.0" layoutY="160.0"
              text="📋  Start Exam" onAction="#handleStart"
              style="-fx-background-color: #6a9ae7;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-background-radius: 8px;
                       -fx-cursor: hand;"
              prefWidth="160.0" prefHeight="45.0"/>

      <!-- View Result Button -->
      <Button fx:id="resultBtn" layoutX="20.0" layoutY="220.0"
              text="📊  View Results" onAction="#handleResult"
              style="-fx-background-color: transparent;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-background-radius: 8px;
                       -fx-cursor: hand;
                       -fx-border-color: #6a9ae7;
                       -fx-border-radius: 8px;"
              prefWidth="160.0" prefHeight="45.0"/>

   </AnchorPane>

   <!-- MAIN CONTENT AREA -->
   <AnchorPane layoutX="200.0" layoutY="70.0" prefHeight="530.0" prefWidth="700.0"
               style="-fx-background-color: #f0f4ff;">

      <!-- Available Exams Section -->
      <Label layoutX="30.0" layoutY="20.0" text="📋 Available Exams"
             style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;"/>

      <!-- Exams TableView -->
      <TableView fx:id="examTable" layoutX="30.0" layoutY="55.0"
                 prefWidth="640.0" prefHeight="180.0">
         <columns>
            <TableColumn fx:id="examName" text="Exam Name" prefWidth="200.0"/>
            <TableColumn fx:id="examSubject" text="Subject" prefWidth="150.0"/>
            <TableColumn fx:id="examDate" text="Date" prefWidth="150.0"/>
            <TableColumn fx:id="examDuration" text="Duration" prefWidth="138.0"/>
         </columns>
      </TableView>


      <!-- Divider -->
      <Label layoutX="0.0" layoutY="295.0" prefWidth="700.0" text=""
             style="-fx-border-color: #c0c8e0; -fx-border-width: 1px 0 0 0;"/>

      <!-- My Results Section -->
      <Label layoutX="30.0" layoutY="310.0" text="📊 My Results"
             style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;"/>

      <!-- Results TableView -->
      <TableView fx:id="resultTable" layoutX="30.0" layoutY="345.0"
                 prefWidth="640.0" prefHeight="160.0">
         <columns>
            <TableColumn fx:id="resultExam" text="Exam Name" prefWidth="200.0"/>
            <TableColumn fx:id="resultScore" text="Score" prefWidth="100.0"/>
            <TableColumn fx:id="resultTotal" text="Total" prefWidth="100.0"/>
            <TableColumn fx:id="resultStatus" text="Status" prefWidth="238.0"/>
         </columns>
      </TableView>

   </AnchorPane>

</AnchorPane>
