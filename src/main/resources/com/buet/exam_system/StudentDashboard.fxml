<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f4ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.StudentDashboardController">

   <!-- TOP BAR -->
   <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="70.0" prefWidth="900.0" style="-fx-background-color: #1a2a4a;">

      <!-- App Title -->
      <Label layoutX="30.0" layoutY="18.0" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="EXAMORA" />

      <!-- Welcome Message -->
      <Label fx:id="welcomeLabel" layoutX="300.0" layoutY="22.0" style="-fx-text-fill: #6a9ae7; -fx-font-size: 18px; -fx-font-weight: bold;" text="WELCOME, Student!" />

      <!-- Logout Button -->
      <Button fx:id="logoutBtn" layoutX="800.0" layoutY="18.0" onAction="#handleLogout" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #e74c3c;                        -fx-text-fill: white;                        -fx-font-size: 14px;                        -fx-background-radius: 8px;                        -fx-cursor: hand;" text="Logout" />
   </AnchorPane>

   <!-- LEFT SIDEBAR -->
   <AnchorPane layoutX="0.0" layoutY="70.0" prefHeight="530.0" prefWidth="200.0" style="-fx-background-color: #1e3a5f;">

      <!-- Student Icon Label -->
      <Label layoutX="75.0" layoutY="30.0" style="-fx-font-size: 50px;" text="👤" />

      <!-- Student Name -->
      <Label fx:id="studentName" alignment="CENTER" layoutX="0.0" layoutY="95.0" prefWidth="200.0" style="-fx-text-fill: white; -fx-font-size: 14px;" text="Student Name" />

      <!-- Divider -->
      <Label layoutX="10.0" layoutY="130.0" prefWidth="180.0" style="-fx-text-fill: #6a9ae7;" text="-------------------------------------" />

      <!-- Profile Button -->
      <Button fx:id="profileBtn" layoutX="20.0" layoutY="160.0" onAction="#handleProfile" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #6a9ae7; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-border-color: #6a9ae7; -fx-border-radius: 8px;" text="👤  Profile" />

      <!-- Start Exam Button -->
      <Button fx:id="startBtn" layoutX="20.0" layoutY="220.0" onAction="#handleStart" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #6a9ae7;                -fx-text-fill: white;                -fx-font-size: 14px;                -fx-background-radius: 8px;                -fx-cursor: hand;" text="📋  Start Exam" />

      <!-- View Result Button -->
      <Button fx:id="resultBtn" layoutX="20.0" layoutY="280.0" onAction="#handleResult" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #6a9ae7; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-border-color: #6a9ae7; -fx-border-radius: 8px;" text="📊  View Results" />

   </AnchorPane>

   <!-- MAIN CONTENT AREA -->
   <AnchorPane layoutX="200.0" layoutY="70.0" prefHeight="530.0" prefWidth="700.0" style="-fx-background-color: #f0f4ff;">

      <!-- Available Exams Section -->
      <Label layoutX="30.0" layoutY="20.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;" text="📋 Available Exams" />

      <!-- Exams TableView -->
      <TableView fx:id="examTable" layoutX="30.0" layoutY="55.0" prefHeight="180.0" prefWidth="640.0">
         <columns>
            <TableColumn fx:id="examName" prefWidth="200.0" text="Exam Name" />
            <TableColumn fx:id="examSubject" prefWidth="150.0" text="Subject" />
            <TableColumn fx:id="examDate" prefWidth="150.0" text="Date" />
            <TableColumn fx:id="examDuration" prefWidth="138.0" text="Duration" />
         </columns>
      </TableView>


      <!-- Divider -->
      <Label layoutX="0.0" layoutY="295.0" prefWidth="700.0" style="-fx-border-color: #c0c8e0; -fx-border-width: 1px 0 0 0;" text="" />

      <!-- My Results Section -->
      <Label layoutX="30.0" layoutY="310.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;" text="📊 My Results" />

      <!-- Results TableView -->
      <TableView fx:id="resultTable" layoutX="30.0" layoutY="345.0" prefHeight="160.0" prefWidth="640.0">
         <columns>
            <TableColumn fx:id="resultExam" prefWidth="200.0" text="Exam Name" />
            <TableColumn fx:id="resultScore" prefWidth="100.0" text="Score" />
            <TableColumn fx:id="resultTotal" prefWidth="100.0" text="Total" />
            <TableColumn fx:id="resultStatus" prefWidth="238.0" text="Status" />
         </columns>
      </TableView>

   </AnchorPane>

</AnchorPane>
