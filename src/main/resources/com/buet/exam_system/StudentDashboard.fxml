<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f4ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.StudentDashboardController">


   <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="70.0" prefWidth="900" style="-fx-background-color: #1a2a4a;">


      <Label layoutX="30.0" layoutY="18.0" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="EXAMORA" />


      <Label fx:id="welcomeLabel" layoutX="199.0" layoutY="22.0" style="-fx-text-fill: #6a9ae7; -fx-font-size: 18px; -fx-font-weight: bold;" text="WELCOME, Student!" />


      <Button fx:id="logoutBtn" layoutX="800" layoutY="17.0" onAction="#handleLogout" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #e74c3c;                        -fx-text-fill: white;                        -fx-font-size: 14px;                        -fx-background-radius: 8px;                        -fx-cursor: hand;" text="Logout" />
   </AnchorPane>


   <AnchorPane layoutX="0.0" layoutY="70.0" prefHeight="530.0" prefWidth="200.0" style="-fx-background-color: #1e3a5f;">


      <Label layoutX="75.0" layoutY="30.0" style="-fx-font-size: 50px;" text="👤" />


      <Label fx:id="studentName" alignment="CENTER" layoutX="0.0" layoutY="95.0" prefWidth="200.0" style="-fx-text-fill: white; -fx-font-size: 14px;" text="Student Name" />


      <Label layoutX="10.0" layoutY="130.0" prefWidth="180.0" style="-fx-text-fill: #6a9ae7;" text="-------------------------------------" />


      <Button fx:id="profileBtn" layoutX="20.0" layoutY="160.0" onAction="#handleProfile" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #6a9ae7; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-border-color: #6a9ae7; -fx-border-radius: 8px;" text="👤  Profile" />


      <Button fx:id="startBtn" layoutX="20.0" layoutY="220.0" onAction="#handleStart" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #6a9ae7;                -fx-text-fill: white;                -fx-font-size: 14px;                -fx-background-radius: 8px;                -fx-cursor: hand;" text="📋  Start Exam" />


      <Button fx:id="resultBtn" layoutX="20.0" layoutY="280.0" onAction="#handleResult" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #6a9ae7; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-border-color: #6a9ae7; -fx-border-radius: 8px;" text="📊  View Results" />
      <Button fx:id="performanceBtn" layoutX="20.0" layoutY="342.0" onAction="#handleResult" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #6a9ae7; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-border-color: #6a9ae7; -fx-border-radius: 8px;" text="📈 Performance" />

   </AnchorPane>
   <AnchorPane layoutX="200.0" layoutY="70.0" prefHeight="530" prefWidth="700" style="-fx-background-color: #f0f4ff;">
      <children>
         <Label layoutX="30" layoutY="25" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;" text="📊 Overview" />
         <AnchorPane layoutX="30" layoutY="60" prefHeight="100" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <children>
               <Label layoutX="15" layoutY="15" style="-fx-font-size: 26px;" text="📋" />
               <Label layoutX="15" layoutY="52" style="-fx-text-fill: #888; -fx-font-size: 12px;" text="Total Exams" />
               <Label fx:id="totalExamsLabel" layoutX="15" layoutY="70" style="-fx-text-fill: #1a2a4a; -fx-font-size: 22px; -fx-font-weight: bold;" text="0" />
            </children>
         </AnchorPane>
         <Label layoutX="0" layoutY="178" prefWidth="700" style="-fx-border-color: #c0c8e0; -fx-border-width: 1px 0 0 0;" text="" />
         <Label layoutX="30" layoutY="195" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;" text="⚡ Quick Actions" />
         <AnchorPane layoutX="30" layoutY="230" prefHeight="140" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <children>
               <Label layoutX="15" layoutY="15" style="-fx-font-size: 34px;" text="📝" />
               <Label layoutX="15" layoutY="62" style="-fx-text-fill: #1a2a4a; -fx-font-size: 14px; -fx-font-weight: bold;" text="Start Exam" />
               <Label layoutX="15" layoutY="83" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Start your desired exam" />
            </children>
         </AnchorPane>
         <AnchorPane layoutX="240" layoutY="230" prefHeight="140" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <children>
               <Label layoutX="15" layoutY="15" style="-fx-font-size: 34px;" text="📈" />
               <Label layoutX="15" layoutY="62" style="-fx-text-fill: #1a2a4a; -fx-font-size: 14px; -fx-font-weight: bold;" text="Performance" />
               <Label layoutX="15" layoutY="83" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Track your" />
               <Label layoutX="15" layoutY="99" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="daily performance" />
            </children>
         </AnchorPane>
         <AnchorPane layoutX="450" layoutY="230" prefHeight="140" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <children>
               <Label layoutX="15" layoutY="15" style="-fx-font-size: 34px;" text="🏆" />
               <Label layoutX="15" layoutY="62" style="-fx-text-fill: #1a2a4a; -fx-font-size: 14px; -fx-font-weight: bold;" text="View Result" />
               <Label layoutX="15" layoutY="83" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Track your" />
               <Label layoutX="15" layoutY="99" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="performance ranks" />
            </children>
         </AnchorPane>
         <Label layoutX="0" layoutY="385" prefWidth="700" style="-fx-border-color: #c0c8e0; -fx-border-width: 1px 0 0 0;" text="" />
      </children>
   </AnchorPane>

</AnchorPane>
