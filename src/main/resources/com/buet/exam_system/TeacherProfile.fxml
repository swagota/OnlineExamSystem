<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.TeacherProfileController">
   <children>
      <Label layoutX="65.0" layoutY="58.0" text="welcome to teacher dashboard!">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <ButtonBar layoutX="354.0" layoutY="303.0" prefHeight="40.0" prefWidth="200.0" />
    <Button fx:id="addQuestionBtn" layoutX="8.0" layoutY="152.0" mnemonicParsing="false" onAction="#handleAddQuestion" prefHeight="26.0" prefWidth="208.0" text="Create Exam" />
      <Button fx:id="availableExamBtn" layoutX="6.0" layoutY="211.0" mnemonicParsing="false" onAction="#handleAvailableExams" prefHeight="26.0" prefWidth="208.0" text="Available Exams" />
      <Button fx:id="leaderboardBtn" layoutX="6.0" layoutY="259.0" mnemonicParsing="false" onAction="#handleLeaderboard" prefHeight="26.0" prefWidth="208.0" text="Leaderboard" />
   </children>
</AnchorPane>
