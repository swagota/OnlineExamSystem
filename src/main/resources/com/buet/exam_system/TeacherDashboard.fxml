<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f4ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.exam_system.TeacherDashboardController">

    <!-- ── TOP BAR ── -->
    <AnchorPane layoutX="0" layoutY="0" prefHeight="70" prefWidth="900" style="-fx-background-color: #1a2a4a;">

        <Label layoutX="30" layoutY="18" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Berlin Sans FB';" text="EXAMORA" />

        <!-- WELCOME LABEL - shows "WELCOME, teachername!" -->
        <Label fx:id="welcomeLabel" layoutX="260" layoutY="22" style="-fx-text-fill: #6a9ae7; -fx-font-size: 18px; -fx-font-weight: bold;" text="WELCOME, Teacher!" />

        <!-- LOGOUT BUTTON -->
        <Button fx:id="logoutBtn" layoutX="800" layoutY="18" onAction="#handleLogout" prefHeight="35" prefWidth="80" style="-fx-background-color: #e74c3c;                        -fx-text-fill: white;                        -fx-font-size: 14px;                        -fx-background-radius: 8px;" text="Logout" />
    </AnchorPane>

    <!-- ── LEFT SIDEBAR ── -->
    <AnchorPane layoutX="0" layoutY="70" prefHeight="530" prefWidth="200" style="-fx-background-color: #1e3a5f;">

        <Label layoutX="66.0" layoutY="21.0" style="-fx-font-size: 50px;" text="👨‍🏫" />

        <!-- TEACHER NAME LABEL -->
        <Label fx:id="teacherName" alignment="CENTER" layoutX="0" layoutY="95" prefWidth="200" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;                       -fx-alignment: center;" text="Teacher Name" />

        <Label layoutX="10" layoutY="125" prefWidth="180" style="-fx-text-fill: #6a9ae7;" text="-------------------------------------" />

        <Button fx:id="addQuestionBtn" layoutX="20" layoutY="155" onAction="#handleAddQuestion" prefHeight="45" prefWidth="160" style="-fx-background-color: #6a9ae7; -fx-text-fill: white;                        -fx-font-size: 14px; -fx-background-radius: 8px;" text="📝  Create Exam" />

        <Button fx:id="availableExamBtn" layoutX="20" layoutY="215" onAction="#handleAvailableExams" prefHeight="45" prefWidth="160" style="-fx-background-color: #6a9ae7; -fx-text-fill: white;                        -fx-font-size: 14px; -fx-background-radius: 8px;" text="📋  Available Exams" />

        <Button fx:id="leaderboardBtn" layoutX="20" layoutY="275" onAction="#handleLeaderboard" prefHeight="45" prefWidth="160" style="-fx-background-color: #6a9ae7; -fx-text-fill: white;                        -fx-font-size: 14px; -fx-background-radius: 8px;" text="🏆  Leaderboard" />
        <Button fx:id="profileBtn" layoutX="20.0" layoutY="333.0" onAction="#handleProfile" prefHeight="45" prefWidth="160" style="-fx-background-color: #6a9ae7; -fx-text-fill: white;                        -fx-font-size: 14px; -fx-background-radius: 8px;" text="👤  Profile" />

    </AnchorPane>

    <!-- ── MAIN CONTENT AREA ── -->
    <AnchorPane layoutX="200" layoutY="70" prefHeight="530" prefWidth="700" style="-fx-background-color: #f0f4ff;">

        <Label layoutX="30" layoutY="25" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;" text="📊 Overview" />

        <!-- Stat Card 1 -->
        <AnchorPane layoutX="30" layoutY="60" prefHeight="100" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <Label layoutX="15" layoutY="15" style="-fx-font-size: 26px;" text="📋" />
            <Label layoutX="15" layoutY="52" style="-fx-text-fill: #888; -fx-font-size: 12px;" text="Total Exams" />
            <Label layoutX="15" layoutY="70" style="-fx-text-fill: #1a2a4a; -fx-font-size: 22px; -fx-font-weight: bold;" text="0" />
        </AnchorPane>

        <!-- Divider -->
        <Label layoutX="0" layoutY="178" prefWidth="700" style="-fx-border-color: #c0c8e0; -fx-border-width: 1px 0 0 0;" text="" />

        <!-- Quick Actions -->
        <Label layoutX="30" layoutY="195" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;" text="⚡ Quick Actions" />

        <!-- Action Card 1 -->
        <AnchorPane layoutX="30" layoutY="230" prefHeight="140" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <Label layoutX="15" layoutY="15" style="-fx-font-size: 34px;" text="📝" />
            <Label layoutX="15" layoutY="62" style="-fx-text-fill: #1a2a4a; -fx-font-size: 14px; -fx-font-weight: bold;" text="Create Exam" />
            <Label layoutX="15" layoutY="83" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Add questions and" />
            <Label layoutX="15" layoutY="99" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="set exam topics" />
        </AnchorPane>

        <!-- Action Card 2 -->
        <AnchorPane layoutX="240" layoutY="230" prefHeight="140" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <Label layoutX="15" layoutY="15" style="-fx-font-size: 34px;" text="📋" />
            <Label layoutX="15" layoutY="62" style="-fx-text-fill: #1a2a4a; -fx-font-size: 14px; -fx-font-weight: bold;" text="View Exams" />
            <Label layoutX="15" layoutY="83" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Browse available" />
            <Label layoutX="15" layoutY="99" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="exams by subject" />
        </AnchorPane>

        <!-- Action Card 3 -->
        <AnchorPane layoutX="450" layoutY="230" prefHeight="140" prefWidth="190" style="-fx-background-color: white; -fx-background-radius: 12px;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);                            -fx-border-color: #dce8ff; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <Label layoutX="15" layoutY="15" style="-fx-font-size: 34px;" text="🏆" />
            <Label layoutX="15" layoutY="62" style="-fx-text-fill: #1a2a4a; -fx-font-size: 14px; -fx-font-weight: bold;" text="Leaderboard" />
            <Label layoutX="15" layoutY="83" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Track student" />
            <Label layoutX="15" layoutY="99" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="performance ranks" />
        </AnchorPane>

        <!-- Divider -->
        <Label layoutX="0" layoutY="385" prefWidth="700" style="-fx-border-color: #c0c8e0; -fx-border-width: 1px 0 0 0;" text="" />

    </AnchorPane>

</AnchorPane>
